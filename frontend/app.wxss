/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 通用按钮样式 */
.button-primary {
  background-color: #1E90FF;
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx;
  text-align: center;
}

.button-primary:disabled {
  background-color: #d9d9d9;
  color: #ffffff;
}

.button-secondary {
  background-color: #ffffff;
  color: #1E90FF;
  border: 1rpx solid #1E90FF;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx;
  text-align: center;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 通用标题样式 */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 通用信息项样式 */
.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: #999999;
  width: 120rpx;
}

.info-value {
  font-size: 22rpx;
  color: #333333;
  flex: 1;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #666666;
  margin-left: 10rpx;
}

/* 空状态 */
.empty {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 按钮点击效果 */
.button:active {
  transform: scale(0.98);
}

/* 卡片点击效果 */
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}