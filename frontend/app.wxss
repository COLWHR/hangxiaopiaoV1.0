/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 通用按钮样式 */
.button-primary {
  background-color: #1E90FF;
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx;
  text-align: center;
}

.button-primary:disabled {
  background-color: #d9d9d9;
  color: #ffffff;
}

.button-secondary {
  background-color: #ffffff;
  color: #1E90FF;
  border: 1rpx solid #1E90FF;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx;
  text-align: center;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 通用标题样式 */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 通用信息项样式 */
.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: #999999;
  width: 120rpx;
}

.info-value {
  font-size: 22rpx;
  color: #333333;
  flex: 1;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #666666;
  margin-left: 10rpx;
}

/* 空状态 */
.empty {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 按钮点击效果 */
.button:active {
  transform: scale(0.98);
}

/* 卡片点击效果 */
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 统一页面布局 */
.page-shell,
.launch-page {
  min-height: 100vh;
  padding: 24rpx;
}

.page-shell {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 30%, #f5f7fb 100%);
}

.hero-card,
.panel-card,
.notice-card,
.activity-card,
.profile-card,
.section,
.card,
.empty-state {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 50rpx rgba(15, 41, 74, 0.08);
}

.hero-card,
.panel-card,
.notice-card,
.activity-card,
.empty-state {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-heading {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  color: #10233f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-meta {
  display: block;
  margin-top: 10rpx;
  color: #6b7a90;
  font-size: 22rpx;
  line-height: 1.6;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
}

.primary-button,
.secondary-button,
.danger-button,
.ghost-button {
  min-width: 160rpx;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
  box-sizing: border-box;
}

.primary-button {
  background: linear-gradient(135deg, #1e90ff, #1677ff);
  color: #ffffff;
}

.secondary-button {
  background: rgba(30, 144, 255, 0.08);
  color: #1e90ff;
}

.danger-button {
  background: rgba(239, 68, 68, 0.12);
  color: #dc2626;
}

.ghost-button {
  background: rgba(16, 35, 63, 0.08);
  color: #10233f;
}

.primary-button::after,
.secondary-button::after,
.danger-button::after,
.ghost-button::after {
  border: none;
}

.field-card,
.form-field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #10233f;
  font-size: 24rpx;
  font-weight: 700;
}

.field-required {
  color: #dc2626;
}

.input-box,
.textarea-box,
.picker-box {
  width: 100%;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dbe7f3;
  background: #ffffff;
  color: #10233f;
  font-size: 26rpx;
  box-sizing: border-box;
}

.textarea-box {
  min-height: 180rpx;
}

.picker-box {
  min-height: 76rpx;
  display: flex;
  align-items: center;
}

.image-field,
.upload-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-image,
.upload-preview {
  width: 100%;
  min-height: 180rpx;
  border-radius: 18rpx;
  background: #edf4fb;
}

.field-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-toggle,
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fbff;
}

.field-toggle-active {
  background: rgba(30, 144, 255, 0.08);
}

.field-toggle-title,
.switch-title {
  display: block;
  color: #10233f;
  font-size: 26rpx;
  font-weight: 700;
}

.field-toggle-desc,
.switch-desc {
  display: block;
  margin-top: 8rpx;
  color: #6b7a90;
  font-size: 22rpx;
  line-height: 1.5;
}

.field-toggle-status {
  color: #1e90ff;
  font-size: 24rpx;
  font-weight: 700;
}

.preview-head,
.preview-section {
  margin-bottom: 20rpx;
}

.preview-title {
  display: block;
  color: #10233f;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.preview-meta,
.preview-content {
  display: block;
  margin-top: 10rpx;
  color: #5e6e84;
  font-size: 24rpx;
  line-height: 1.7;
}

.list-card {
  overflow: hidden;
}

.list-card-highlight {
  box-shadow: 0 0 0 4rpx rgba(31, 143, 255, 0.2), 0 18rpx 36rpx rgba(31, 42, 55, 0.08);
}

.list-cover {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
}

.list-body {
  padding-top: 20rpx;
}

.list-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.list-title {
  flex: 1;
  color: #10233f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.list-summary {
  display: block;
  margin-top: 14rpx;
  color: #506179;
  font-size: 25rpx;
  line-height: 1.7;
}

.list-meta {
  display: block;
  margin-top: 10rpx;
  color: #6b7a90;
  font-size: 23rpx;
}

.list-actions {
  margin-top: 20rpx;
}

.error-banner {
  margin: 10rpx 0 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fff1f2;
  color: #dc2626;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-title {
  display: block;
  color: #10233f;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #6b7a90;
  font-size: 24rpx;
  line-height: 1.6;
}

.page-bottom-actions {
  margin-bottom: 28rpx;
}

.mini-action {
  width: 200rpx;
  height: 74rpx;
  line-height: 74rpx;
  font-size: 26rpx;
}

.activities-hero {
  margin-bottom: 24rpx;
}

.activities-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7a90;
  font-size: 24rpx;
  line-height: 1.7;
}
