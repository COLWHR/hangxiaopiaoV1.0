<view class="container">
  <image src="{{activity.coverImageUrl}}" mode="aspectFill" class="activity-image"></image>

  <view class="activity-card">
    <text class="activity-title">{{activity.title}}</text>
    <text class="activity-description">{{activity.description}}</text>

    <view class="countdown-section" wx:if="{{isCounting}}">
      <text class="countdown-title">{{countdownTitle}}</text>
      <view class="countdown">
        <view class="countdown-item">
          <text class="countdown-number">{{countdown.days}}</text>
          <text class="countdown-label">天</text>
        </view>
        <text class="countdown-separator">:</text>
        <view class="countdown-item">
          <text class="countdown-number">{{countdown.hoursFormatted}}</text>
          <text class="countdown-label">时</text>
        </view>
        <text class="countdown-separator">:</text>
        <view class="countdown-item">
          <text class="countdown-number">{{countdown.minutesFormatted}}</text>
          <text class="countdown-label">分</text>
        </view>
        <text class="countdown-separator">:</text>
        <view class="countdown-item">
          <text class="countdown-number">{{countdown.secondsFormatted}}</text>
          <text class="countdown-label">秒</text>
        </view>
      </view>
    </view>

    <view class="activity-info">
      <view class="info-item">
        <text class="info-label">活动时间:</text>
        <text class="info-value">{{activity.displayStartTime}} - {{activity.displayEndTime}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动地点:</text>
        <text class="info-value">{{activity.location}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">总票数:</text>
        <text class="info-value">{{activity.totalTickets}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">剩余票数:</text>
        <text class="info-value ticket-count" wx:if="{{hasAvailableTickets}}">{{activity.availableTickets}}</text>
        <text class="info-value sold-out" wx:else>已售罄</text>
      </view>
    </view>

    <view class="rules-section">
      <text class="rules-title">活动规则</text>
      <view class="rules-list">
        <view wx:for="{{activity.rules}}" wx:key="index" class="rule-item">
          <text class="rule-number">{{index + 1}}.</text>
          <text class="rule-text">{{item}}</text>
        </view>
      </view>
    </view>

    <button class="book-button" bindtap="bookTicket" disabled="{{!canBook}}">
      {{bookButtonText}}
    </button>
  </view>
</view>
