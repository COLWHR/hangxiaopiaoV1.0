.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 活动图片 */
.activity-image {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
  display: block;
}

.activity-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin: 0 20rpx 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.activity-description {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  display: block;
  line-height: 1.5;
}

/* 倒计时 */
.countdown-section {
  background: linear-gradient(135deg, #f0f8ff 0%, #e6f7ff 100%);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #bae7ff;
}

.countdown-title {
  font-size: 28rpx;
  color: #1E90FF;
  margin-bottom: 20rpx;
  display: block;
  text-align: center;
  font-weight: bold;
}

.countdown {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.countdown-item {
  background: linear-gradient(135deg, #1E90FF 0%, #0066cc 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  min-width: 70rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 144, 255, 0.3);
}

.countdown-number {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.countdown-label {
  font-size: 18rpx;
  display: block;
  margin-top: 4rpx;
  opacity: 0.9;
}

.countdown-separator {
  font-size: 36rpx;
  font-weight: bold;
  color: #1E90FF;
}

.activity-info {
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  width: 120rpx;
}

.info-value {
  font-size: 22rpx;
  color: #333;
  flex: 1;
}

.ticket-count {
  color: #ff4d4f;
  font-weight: bold;
}

.sold-out {
  color: #ff4d4f;
}

.status-active {
  color: #1890ff;
}

.status-pending {
  color: #fa8c16;
}

.status-ended {
  color: #999;
}

/* 活动规则 */
.rules-section {
  margin-bottom: 30rpx;
}

.rules-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.rules-list {
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
}

.rule-item {
  display: flex;
  margin-bottom: 10rpx;
  align-items: flex-start;
}

.rule-number {
  font-size: 22rpx;
  color: #1E90FF;
  font-weight: bold;
  margin-right: 10rpx;
  min-width: 30rpx;
}

.rule-text {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  line-height: 1.4;
}

.book-button {
  width: 100%;
  height: 90rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  background: linear-gradient(135deg, #1E90FF 0%, #0066cc 100%);
  border-radius: 45rpx;
  margin-top: 20rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(30, 144, 255, 0.4);
}

.book-button:disabled {
  background: linear-gradient(135deg, #d9d9d9 0%, #bfbfbf 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.book-button:active:not(:disabled) {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(30, 144, 255, 0.3);
}