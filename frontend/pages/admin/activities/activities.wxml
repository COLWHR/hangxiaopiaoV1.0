<view class="page-shell">
  <view class="hero-card activities-hero">
    <view class="section-heading">
      <view>
        <text class="section-title">活动管理</text>
        <text class="activities-subtitle">支持新建、编辑、撤回和重新发布，所有改动都会回写到后端。</text>
      </view>
      <button class="primary-button mini-action" bindtap="handleCreateNew">新建活动</button>
    </view>
  </view>

  <block wx:if="{{activities.length}}">
    <block wx:for="{{activities}}" wx:key="id">
      <view class="activity-card list-card {{highlightId === item.id ? 'list-card-highlight' : ''}}">
        <image class="list-cover" src="{{item.coverImage}}" mode="aspectFill" />
        <view class="list-body">
          <view class="list-head">
            <text class="list-title">{{item.title}}</text>
            <status-pill label="{{item.statusMeta.label}}" className="{{item.statusMeta.className}}" />
          </view>
          <text class="list-summary">{{item.summary}}</text>
          <text class="list-meta">时间：{{item.displayTime}}</text>
          <text class="list-meta">地点：{{item.location}}</text>
          <text class="list-meta">字段：{{item.activeFields}}</text>
          <text class="list-meta">票数：{{item.availableTickets}} / {{item.totalTickets}}</text>
          <view class="button-row list-actions">
            <button class="secondary-button" data-id="{{item.id}}" bindtap="handleViewPreview">查看预览</button>
            <button class="secondary-button" data-id="{{item.id}}" bindtap="handleEdit">
              {{item.status === 'revoked' ? '重新发布' : '编辑活动'}}
            </button>
            <button wx:if="{{item.status === 'published'}}" class="danger-button" data-id="{{item.id}}" bindtap="handleRevoke">
              撤回活动
            </button>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view wx:else class="panel-card empty-state">
    <text class="empty-title">还没有已发布活动</text>
    <text class="empty-desc">先新建一条活动，提交预览后发布到后端，用户端就能看到并抢票。</text>
  </view>

  <view class="button-row page-bottom-actions">
    <button class="secondary-button" bindtap="handleBackToSelect">切换角色</button>
    <button class="danger-button" bindtap="handleLogout">退出登录</button>
  </view>
</view>
