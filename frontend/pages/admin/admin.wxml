<view class="container">
  <!-- 负责人身份验证界面 -->
  <view wx:if="{{!isAuthenticated}}" class="auth-section">
    <view class="auth-header">
      <text class="auth-title">负责人身份验证</text>
      <text class="auth-subtitle">请输入负责人编号以继续</text>
    </view>
    
    <view class="auth-form">
      <view class="input-group">
        <text class="input-label">负责人编号</text>
        <input 
          class="input-field" 
          type="text" 
          placeholder="请输入负责人编号" 
          value="{{authCode}}"
          bindinput="onAuthCodeInput"
          maxlength="20"
        />
      </view>
      
      <view wx:if="{{authError}}" class="error-message">
        {{authError}}
      </view>
      
      <button 
        class="auth-button" 
        bindtap="onAuthSubmit"
        disabled="{{isAuthenticating}}"
      >
        {{isAuthenticating ? '验证中...' : '验证'}}
      </button>
    </view>
    
    <view class="auth-tips">
      <text class="tips-title">温馨提示：</text>
      <text class="tips-item">• 负责人编号由系统管理员统一分配</text>
      <text class="tips-item">• 如忘记编号请联系系统管理员</text>
    </view>
  </view>

  <!-- 活动上传表单界面 -->
  <view wx:else class="upload-section">
    <!-- 顶部导航 -->
    <view class="upload-header">
      <view class="header-left" bindtap="onBack">
        <text class="back-icon">←</text>
      </view>
      <text class="header-title">发布新活动</text>
      <view class="header-right"></view>
    </view>

    <!-- 表单填写进度 -->
    <view class="progress-section">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{formProgress}}%"></view>
      </view>
      <text class="progress-text">已完成 {{formProgress}}%</text>
    </view>

    <scroll-view class="form-scroll" scroll-y="true">
      <!-- 活动名称 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>活动名称</text>
        </view>
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入活动名称（5-50个字符）" 
          value="{{formData.title}}"
          bindinput="onTitleInput"
          maxlength="50"
        />
        <view class="char-count">{{formData.title.length}}/50</view>
      </view>

      <!-- 活动日期 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>活动日期</text>
        </view>
        <view class="date-picker-group">
          <view class="date-picker-item">
            <text class="date-label">开始时间</text>
            <picker 
              mode="multiSelector" 
              range="{{dateTimeRange}}" 
              range-key="{{'label'}}"
              value="{{startDateTimeIndex}}"
              bindchange="onStartDateTimeChange"
            >
              <view class="picker-display">
                {{formData.startTime || '请选择开始时间'}}
              </view>
            </picker>
          </view>
          <view class="date-picker-item">
            <text class="date-label">结束时间</text>
            <picker 
              mode="multiSelector" 
              range="{{dateTimeRange}}" 
              range-key="{{'label'}}"
              value="{{endDateTimeIndex}}"
              bindchange="onEndDateTimeChange"
            >
              <view class="picker-display">
                {{formData.endTime || '请选择结束时间'}}
              </view>
            </picker>
          </view>
        </view>
      </view>

      <!-- 活动地点 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>活动地点</text>
        </view>
        <view class="location-group">
          <input 
            class="form-input location-input" 
            type="text" 
            placeholder="请输入活动地点" 
            value="{{formData.location}}"
            bindinput="onLocationInput"
          />
          <button class="location-btn" bindtap="onChooseLocation">选择位置</button>
        </view>
      </view>

      <!-- 总票数 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>总票数</text>
        </view>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入总票数" 
          value="{{formData.totalTickets}}"
          bindinput="onTotalTicketsInput"
        />
      </view>

      <!-- 活动描述 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>活动描述</text>
        </view>
        <textarea 
          class="form-textarea" 
          placeholder="请输入活动描述" 
          value="{{formData.description}}"
          bindinput="onDescriptionInput"
          maxlength="500"
          auto-height
        />
        <view class="char-count">{{formData.description.length}}/500</view>
      </view>

      <!-- 参与对象 -->
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>参与对象</text>
        </view>
        <picker 
          mode="selector" 
          range="{{participantOptions}}" 
          value="{{participantIndex}}"
          bindchange="onParticipantChange"
        >
          <view class="picker-display">
            {{formData.participant || '请选择参与对象'}}
          </view>
        </picker>
      </view>

      <!-- 活动海报 -->
      <view class="form-item">
        <view class="form-label">活动海报</view>
        <view class="poster-upload" bindtap="onChoosePoster">
          <image wx:if="{{formData.posterUrl}}" src="{{formData.posterUrl}}" class="poster-preview" mode="aspectFill" />
          <view wx:else class="poster-placeholder">
            <text class="poster-icon">📷</text>
            <text class="poster-text">点击上传海报</text>
            <text class="poster-tip">支持jpg/png格式，最大5MB</text>
          </view>
        </view>
        <view wx:if="{{posterUploadProgress > 0 && posterUploadProgress < 100}}" class="upload-progress">
          <view class="progress-bar-small">
            <view class="progress-fill-small" style="width: {{posterUploadProgress}}%"></view>
          </view>
          <text class="progress-text-small">上传中 {{posterUploadProgress}}%</text>
        </view>
      </view>

      <!-- 表单验证提示 -->
      <view wx:if="{{formError}}" class="form-error">
        {{formError}}
      </view>

      <!-- 底部按钮区域 -->
      <view class="button-group">
        <button class="btn-secondary" bindtap="onSaveDraft">保存草稿</button>
        <button 
          class="btn-primary" 
          bindtap="onSubmit"
          disabled="{{isSubmitting}}"
        >
          {{isSubmitting ? '提交中...' : '提交审核'}}
        </button>
      </view>
    </scroll-view>
  </view>
</view>
