<view class="page-shell">
  <view class="hero-card">
    <view class="section-heading">
      <view>
        <text class="section-title">发布预览</text>
        <text class="section-meta">确认内容无误后即可发布到用户端。</text>
      </view>
      <status-pill label="{{statusMeta.label}}" className="{{statusMeta.className}}" />
    </view>
  </view>

  <view class="panel-card">
    <view class="preview-head">
      <text class="preview-title">{{preview.title}}</text>
      <text class="preview-meta">{{formattedStartTime}} - {{formattedEndTime}}</text>
      <text class="preview-meta">{{preview.location}}</text>
    </view>

    <image wx:if="{{preview.coverImage}}" src="{{preview.coverImage}}" class="preview-image" mode="aspectFill" />

    <view class="preview-section">
      <text class="section-title">活动简介</text>
      <text class="preview-content">{{preview.summary}}</text>
    </view>

    <view class="preview-section">
      <text class="section-title">报名字段</text>
      <text class="preview-content">{{registrationFieldLabels}}</text>
    </view>

    <view class="preview-section">
      <text class="section-title">票根规则</text>
      <text class="preview-content">{{preview.ticketStubSlogan}} / {{preview.ticketNumberPrefix}} / {{preview.seatRule}}</text>
    </view>
  </view>

  <view class="button-row">
    <button class="secondary-button" bindtap="handleBackToEdit">返回编辑</button>
    <button class="primary-button" bindtap="handlePublish">{{confirmButtonText}}</button>
  </view>
</view>
