.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #1E90FF;
  color: #fff;
  padding: 20rpx;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.search-bar {
  background-color: #fff;
  padding: 15rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 10rpx 15rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  color: #999;
}

.input {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 15rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 10rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 20rpx;
}

.filter-item.active {
  background-color: #e6f7ff;
  color: #1E90FF;
}

.activity-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.activity-image {
  width: 100%;
  height: 250rpx;
}

.activity-content {
  padding: 20rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.activity-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
  line-height: 1.3;
}

.status {
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  font-size: 18rpx;
}

.status.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status.ended {
  background-color: #f5f5f5;
  color: #999;
}

.status.pending {
  background-color: #fff7e6;
  color: #d48806;
}

.status.sold-out {
  background-color: #fff1f0;
  color: #cf1322;
}

.status.revoked {
  background-color: #f5f5f5;
  color: #64748b;
}

.activity-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 22rpx;
}

.info-label {
  color: #999;
  width: 100rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.ticket-count {
  color: #ff4d4f;
  font-weight: bold;
}

.activity-footer {
  display: flex;
  justify-content: center;
}

.book-button {
  width: 100%;
  background-color: #1E90FF;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.book-button:disabled {
  background-color: #d9d9d9;
  color: #999;
}

.empty {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}
