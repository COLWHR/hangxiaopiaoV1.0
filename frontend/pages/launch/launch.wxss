.launch-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at top left, rgba(30, 144, 255, 0.18), transparent 42%),
    radial-gradient(circle at top right, rgba(15, 41, 74, 0.12), transparent 36%),
    linear-gradient(180deg, #f6fbff 0%, #ffffff 52%, #eef4fb 100%);
}

.hero {
  margin-bottom: 28rpx;
  padding: 18rpx 4rpx 8rpx;
}

.eyebrow {
  display: block;
  color: #1e90ff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #10233f;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: #5e6e84;
  font-size: 26rpx;
  line-height: 1.6;
}

.mode-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mode-card {
  padding: 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(15, 41, 74, 0.08);
}

.mode-user {
  background: linear-gradient(135deg, rgba(30, 144, 255, 0.16) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.mode-admin {
  background: linear-gradient(135deg, rgba(16, 35, 63, 0.12) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.mode-tag {
  display: inline-flex;
  margin-bottom: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(16, 35, 63, 0.08);
  color: #10233f;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-title {
  display: block;
  color: #10233f;
  font-size: 34rpx;
  font-weight: 800;
}

.mode-desc {
  display: block;
  margin-top: 12rpx;
  color: #5e6e84;
  font-size: 24rpx;
  line-height: 1.6;
}

.mode-action {
  display: block;
  margin-top: 22rpx;
  color: #1e90ff;
  font-size: 24rpx;
  font-weight: 700;
}

.status-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 26rpx rgba(15, 41, 74, 0.05);
}

.status-title {
  display: block;
  color: #10233f;
  font-size: 28rpx;
  font-weight: 700;
}

.status-line {
  display: block;
  margin-top: 10rpx;
  color: #60708b;
  font-size: 22rpx;
  line-height: 1.6;
}
