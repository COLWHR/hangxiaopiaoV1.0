<view class="page">
  <view class="profile-card">
    <image src="{{userInfo.avatarUrl}}" class="avatar"></image>
    <view class="profile-meta">
      <text class="name">{{userInfo.nickname || userInfo.name}}</text>
      <text class="student-id">{{userInfo.studentId}}</text>
      <text class="detail">{{userInfo.college}}</text>
      <text class="detail">{{userInfo.className}}</text>
      <text class="detail">{{userInfo.phone}}</text>
    </view>
    <view class="edit-button" bindtap="onEditProfile">
      <text>编辑资料</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">我的票根</text>
      <text class="section-more" bindtap="onViewAllTickets">查看全部</text>
    </view>

    <view class="ticket-list">
      <view
        wx:for="{{tickets}}"
        wx:key="id"
        class="ticket-card"
        bindtap="onTicketTap"
        data-ticket-number="{{item.ticketNumber}}"
      >
        <view class="ticket-header">
          <text class="ticket-title">{{item.activityTitle}}</text>
          <text class="ticket-status {{item.status === 'valid' ? 'valid' : 'used'}}">
            {{item.status === 'valid' ? '有效' : '已使用'}}
          </text>
        </view>

        <view class="ticket-info">
          <view class="info-row">
            <text class="info-label">时间</text>
            <text class="info-value">{{item.time}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">地点</text>
            <text class="info-value">{{item.location}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">座位</text>
            <text class="info-value">{{item.seatNumber}}</text>
          </view>
        </view>

        <view class="ticket-qr">
          <image src="{{item.qrCode}}" class="qr-code"></image>
          <text class="ticket-number">{{item.ticketNumber}}</text>
        </view>
      </view>

      <view wx:if="{{tickets.length === 0}}" class="empty">
        <text>暂无票根，先去抢票吧</text>
      </view>
    </view>
  </view>
</view>
