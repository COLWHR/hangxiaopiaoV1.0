.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 30%, #f5f7fb 100%);
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 50rpx rgba(15, 41, 74, 0.08);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eaf2ff;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  color: #10233f;
  font-size: 34rpx;
  font-weight: 700;
}

.student-id {
  display: block;
  margin-top: 6rpx;
  color: #1e90ff;
  font-size: 24rpx;
  font-weight: 600;
}

.detail {
  display: block;
  margin-top: 6rpx;
  color: #60708b;
  font-size: 22rpx;
  line-height: 1.5;
}

.edit-button {
  align-self: flex-start;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(30, 144, 255, 0.12);
  color: #1e90ff;
  font-size: 22rpx;
  font-weight: 600;
}

.section {
  margin-top: 24rpx;
  padding: 24rpx 20rpx 8rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(15, 41, 74, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-title {
  color: #10233f;
  font-size: 30rpx;
  font-weight: 700;
}

.section-more {
  color: #1e90ff;
  font-size: 22rpx;
}

.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ticket-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border: 1rpx solid #e7eef8;
}

.ticket-cover {
  width: 100%;
  height: 180rpx;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ticket-title {
  flex: 1;
  color: #10233f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.ticket-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.ticket-status.valid {
  background: rgba(46, 204, 113, 0.12);
  color: #16a34a;
}

.ticket-status.used {
  background: rgba(148, 163, 184, 0.16);
  color: #64748b;
}

.ticket-info {
  padding-top: 16rpx;
  border-top: 1rpx solid #edf2f7;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.info-label {
  color: #7a8798;
}

.info-value {
  flex: 1;
  color: #20324d;
  text-align: right;
}

.ticket-qr {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2f7;
}

.qr-code {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f4f8fd;
}

.ticket-number {
  flex: 1;
  color: #60708b;
  font-size: 20rpx;
  word-break: break-all;
}

.empty {
  padding: 40rpx 0 24rpx;
  color: #8a98ad;
  font-size: 24rpx;
  text-align: center;
}
