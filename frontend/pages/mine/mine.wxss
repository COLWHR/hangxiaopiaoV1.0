.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息区域 */
.user-info {
  background-color: #1E90FF;
  padding: 40rpx 20rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.user-student-id {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.edit-button {
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 功能菜单 */
.menu-section {
  background-color: #fff;
  margin-top: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.menu-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 票根展示 */
.ticket-section {
  margin: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #1E90FF;
}

.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ticket-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.ticket-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.ticket-status {
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  font-size: 18rpx;
  background-color: #e6f7ff;
  color: #1890ff;
}

.ticket-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 22rpx;
}

.info-label {
  color: #999;
  width: 100rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.ticket-qr {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.qr-code {
  width: 120rpx;
  height: 120rpx;
  margin-right: 20rpx;
}

.ticket-number {
  flex: 1;
  font-size: 20rpx;
  color: #666;
  word-break: break-all;
}

.empty {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}