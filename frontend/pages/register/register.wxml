<view class="page">
  <view class="hero">
    <text class="eyebrow">航小票</text>
    <text class="title">{{pageTitle}}</text>
    <text class="subtitle">{{pageSubtitle}}</text>
  </view>

  <view class="card">
    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>姓名</text>
      </view>
      <input
        class="form-input"
        type="text"
        placeholder="请输入真实姓名"
        value="{{formData.name}}"
        maxlength="20"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>学号</text>
      </view>
      <input
        class="form-input"
        type="number"
        placeholder="请输入 12 位学号"
        value="{{formData.studentId}}"
        maxlength="12"
        bindinput="onStudentIdInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>学院</text>
      </view>
      <picker
        mode="selector"
        range="{{collegeOptions}}"
        value="{{collegeIndex}}"
        bindchange="onCollegeChange"
      >
        <view class="form-input picker {{formData.college ? 'filled' : 'placeholder'}}">
          {{formData.college || '请选择学院'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>班级</text>
      </view>
      <input
        class="form-input"
        type="text"
        placeholder="例如 XX2001"
        value="{{formData.className}}"
        maxlength="30"
        bindinput="onClassNameInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>手机号码</text>
      </view>
      <input
        class="form-input"
        type="number"
        placeholder="登录手机号"
        value="{{formData.phone}}"
        maxlength="11"
        disabled="{{phoneLocked}}"
      />
    </view>

    <view wx:if="{{formError}}" class="form-error">
      <text>{{formError}}</text>
    </view>

    <button class="submit-button" bindtap="onRegister" disabled="{{isSubmitting}}">
      {{isSubmitting ? '保存中...' : '保存并继续'}}
    </button>

    <view class="tip">
      <text>提交后会同步到数据库和“我的”页面。</text>
    </view>
  </view>
</view>
