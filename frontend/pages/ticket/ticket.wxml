<view class="container">
  <view class="ticket-card">
    <image wx:if="{{ticket.activity.coverImageUrl}}" src="{{ticket.activity.coverImageUrl}}" mode="aspectFill" class="ticket-cover"></image>

    <view class="ticket-header">
      <text class="ticket-title">票根详情</text>
    </view>

    <view class="ticket-info">
      <view class="info-item">
        <text class="info-label">门票编号:</text>
        <text class="info-value">{{ticket.ticketNumber}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">座位号:</text>
        <text class="info-value">{{ticket.seatNumber}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动名称:</text>
        <text class="info-value">{{ticket.activity.title}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动时间:</text>
        <text class="info-value">{{ticket.activity.startTime}} - {{ticket.activity.endTime}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动地点:</text>
        <text class="info-value">{{ticket.activity.location}}</text>
      </view>
    </view>

    <view class="qr-code">
      <image wx:if="{{ticket.ticketStub.qrCodeUrl}}" src="{{ticket.ticketStub.qrCodeUrl}}" mode="aspectFit" class="qr-code-image"></image>
      <text class="qr-code-text">扫码核验</text>
    </view>

    <view class="ticket-footer">
      <text class="footer-text">感谢你的参与</text>
    </view>
  </view>
</view>
