<view class="container">
  <view class="ticket-card">
    <view class="ticket-header">
      <text class="ticket-title">纪念票根</text>
    </view>
    
    <view class="ticket-info">
      <view class="info-item">
        <text class="info-label">门票编号:</text>
        <text class="info-value">{{ticket.ticketNumber}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">座位号:</text>
        <text class="info-value">{{ticket.seatNumber}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动名称:</text>
        <text class="info-value">{{ticket.activity.title}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动时间:</text>
        <text class="info-value">{{ticket.activity.startTime}} - {{ticket.activity.endTime}}</text>
      </view>
    </view>
    
    <view class="qr-code">
      <image src="{{ticket.ticketStub.qrCodeUrl}}" mode="aspectFit" class="qr-code-image" />
      <text class="qr-code-text">扫码验证</text>
    </view>
    
    <view class="ticket-footer">
      <text class="footer-text">感谢您的参与</text>
    </view>
  </view>
</view>